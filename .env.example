# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Protects the reminder cron endpoint (Vercel Cron sends this as a bearer token)
CRON_SECRET=dev-cron-secret

# ---- Phase D integrations (not required for the local MVP) ----
# The MVP runs entirely on a local JSON store + stubbed providers.
# Fill these in to swap the stubs for live services.

# Supabase (Postgres / Auth / Storage)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Stripe Billing (techs subscribing to Glow) + Connect (client deposits)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_TRIAL=price_...    # £2 / 14 days (trial phase)
# STRIPE_PRICE_MONTHLY=price_...  # £19 / month
# STRIPE_PRICE_ANNUAL=price_...   # £180 / year
# PAYMENTS_PROVIDER=stripe

# Resend (email reminders)
# RESEND_API_KEY=re_...
# RESEND_FROM=Glow <bookings@yourdomain.com>   # verified domain; defaults to onboarding@resend.dev

# Twilio (SMS reminders)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# Error monitoring: where server error alerts are emailed (via Resend)
# OPS_ALERT_EMAIL=you@yourdomain.com

# Where "Share an idea" feedback from techs is emailed (falls back to OPS_ALERT_EMAIL)
# FEEDBACK_EMAIL=you@yourdomain.com

# Owner page access is hardcoded in lib/admin.ts (brian@thesupportsdesk.com + briancollins454@mail.com).
# ADMIN_EMAILS is no longer used — remove it from Vercel if present.

# Where new-signup alerts are emailed (defaults to support@glow-uk.com)
# SIGNUP_ALERT_EMAIL=support@glow-uk.com

# Google Calendar direct sync
# Create OAuth credentials in Google Cloud and add this redirect URI:
#   http://localhost:3000/api/google/calendar/callback
#   https://your-domain.com/api/google/calendar/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
