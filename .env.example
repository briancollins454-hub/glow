# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Protects the reminder cron endpoint (Vercel Cron sends this as a bearer token)
CRON_SECRET=dev-cron-secret

# ---- Phase D integrations (not required for the local MVP) ----
# The MVP runs entirely on a local JSON store + stubbed providers.
# Fill these in to swap the stubs for live services.

# Supabase (Postgres / Auth / Storage)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Stripe Connect (deposits + balance)
# PAYMENTS_PROVIDER=stripe
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Resend (email reminders)
# RESEND_API_KEY=

# Twilio (SMS reminders)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
