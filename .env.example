# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Protects the reminder cron endpoint (Vercel Cron sends this as a bearer token)
CRON_SECRET=dev-cron-secret

# ---- Phase D integrations (not required for the local MVP) ----
# The MVP runs entirely on a local JSON store + stubbed providers.
# Fill these in to swap the stubs for live services.

# Supabase (Postgres / Auth / Storage)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Stripe Billing (techs subscribing to Glow) + Connect (client deposits)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_TRIAL=price_...    # £2 / 14 days (trial phase)
# STRIPE_PRICE_MONTHLY=price_...  # £19 / month
# STRIPE_PRICE_ANNUAL=price_...   # £180 / year
# PAYMENTS_PROVIDER=stripe

# Resend (email reminders)
# RESEND_API_KEY=

# Twilio (SMS reminders)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
